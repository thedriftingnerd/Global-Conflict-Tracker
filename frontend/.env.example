# Environment Configuration Template
# Copy this to .env and update values as needed

# Backend API
REACT_APP_API_URL=http://localhost:5000

# App Settings
REACT_APP_TITLE=Conflict Tracker
REACT_APP_DESCRIPTION=Real-time monitoring of global conflicts

# Feature Flags
REACT_APP_ENABLE_NEWS=true
REACT_APP_ENABLE_STATS=true

# Optional: Analytics
# REACT_APP_ANALYTICS_KEY=your_key_here
